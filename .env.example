# ============================================================
# KnowBrain（知脑）环境变量配置
# 复制此文件为 .env 后修改
#   Linux/macOS: cp .env.example .env
#   Windows:     copy .env.example .env
# ============================================================

# ---- 数据库 ----
MYSQL_ROOT_PASSWORD=knowbrain123
MYSQL_PORT=3306
REDIS_PASSWORD=knowbrain_redis_2024
REDIS_PORT=6379

# ---- 对象存储 ----
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowbrain-documents
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- 向量数据库 ----
MILVUS_GRPC_PORT=19530
MILVUS_METRIC_PORT=9091

# ---- LLM API（必填！否则无法问答）----
# 阿里云 DashScope: https://dashscope.aliyuncs.com/compatible-mode
# DeepSeek:          https://api.deepseek.com
SPRING_AI_OPENAI_API_KEY=sk-your-api-key-here
SPRING_AI_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
SPRING_AI_OPENAI_CHAT_MODEL=qwen-max
SPRING_AI_OPENAI_EMBEDDING_MODEL=text-embedding-v4

# ---- JWT 安全（生产环境请更换为随机字符串）----
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# ---- 服务端口 ----
SERVER_PORT=8080
NGINX_PORT=80
